{
  "name": "playwrighte2etestframework",
  "version": "1.0.0",
  "description": "This is playwright e2e test framework project",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test:apiframework": "npx playwright test  --config=config/test.playwright.config.ts  tests/api/framework.friendly.users.api.spec.ts",
    "test:api": "npx playwright test  --config=config/test.playwright.config.ts  tests/api/users.api.spec.ts",
    "test:e2e": "npx playwright test  --config=config/test.playwright.config.ts  tests/e2e/nopcommerce.e2e.spec.ts --headed",
    "test:e2etest": "npx playwright test  --config=config/test.playwright.config.ts  tests/e2e/nopcommerce.e2etest.spec.ts --headed",
    "test:e2etestexp": "npx playwright test  --config=config/test.playwright.config.ts  tests/e2e/experiment.nopcommerce.e2etest.spec.ts --headed",
    "dev:make-apt": "npx playwright test  --config=config/dev.playwright.config.ts  tests/functional/env.config.make.appt.spec.ts --headed",
    "test:make-apt": "npx playwright test  --config=config/test.playwright.config.ts  tests/functional/env.config.make.appt.spec.ts --headed",
    "demo:csvparams": "npx playwright test tests/demo/csvparams.make.appt.spec.ts --headed",
    "demo:params": "npx playwright test tests/demo/params.make.appt.spec.ts --headed",
    "demo:tag": "npx playwright test --grep @smoke --headed",
    "debug:cli2": "npx playwright test tests/demo/debug.make.appt.spec.ts --debug",
    "debug:cli": "set PWDEBUG=1 && npx playwright test tests/demo/debug.make.appt.spec.ts",
    "debug:trace": "npx playwright test tests/demo/debug.make.appt.spec.ts --trace on",
    "debug:ui": "npx playwright test tests/demo/debug.make.appt.spec.ts --ui --headed",
    "debug": "npx playwright test tests/demo/debug.make.appt.spec.ts --headed",
    "inventory": "npx playwright test tests/functional/inventory.spec.ts --headed",
    "ele-int": "npx playwright test tests/demo/ele.handling.make.appt.spec.ts --headed",
    "login": "npx playwright test  tests/functional/login.spec.ts --headed",
    "make-apt": "npx playwright test  tests/functional/make.appt.spec.ts --headed",
    "log:make-apt": "npx playwright test  tests/functional/logger.make.appt.spec.ts --headed",
    "multi-window": "npx playwright test tests/functional/multi.window.spec.ts --headed",
    "demo": "npx playwright test tests/demo/mytest.spec.ts --headed ",
    "demo:firefox": "npx playwright test tests/demo/mytest.spec.ts --project=firefox --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-playwright": "^3.9.0",
    "chalk": "^5.6.2",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2"
  }
 
}
